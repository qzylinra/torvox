<?xml version="1.0" encoding="utf-8"?>
<!-- notification icon: terminal prompt silhouette for status bar -->
<!-- Must be single-color silhouette (Android tints notification icons) -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Terminal window outline -->
    <path
        android:pathData="M3,5 C3,3.9 3.9,3 5,3 L19,3 C20.1,3 21,3.9 21,5 L21,17 C21,18.1 20.1,19 19,19 L5,19 C3.9,19 3,18.1 3,17 Z"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"/>

    <!-- Title bar line -->
    <path
        android:pathData="M3,6.5 L21,6.5"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="0.8"/>

    <!-- Chevron ">" -->
    <path
        android:pathData="M7,11.5 L11,14.5 L7,17.5"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>

    <!-- Cursor "_" -->
    <path
        android:pathData="M13,17 L18,17"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

</vector>
