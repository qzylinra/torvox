# OpenClaude — free-only proxy configuration (no API key required).
#
# This file is meant to be sourced so the variables are exported into the
# environment, e.g.:
#
#   HOME=/tmp/ocz_home bash -c 'source examples/openclaude.env && node bin/openclaude -p "hello" --dangerously-skip-permissions --output-format text'
#
# Using an isolated HOME keeps your real OpenClaude config untouched; the proxy
# is registered purely through these environment variables.

# Force OpenClaude into its OpenAI-compatible mode (required for custom gateways).
export CLAUDE_CODE_USE_OPENAI=1

# Point at the local free-only proxy. Keep the /v1 suffix.
export OPENAI_BASE_URL=http://127.0.0.1:8787/v1

# Raw free model id (no provider/ prefix). Must be one of the ids returned by
# GET http://127.0.0.1:8787/v1/models (fetched dynamically on each start).
export OPENAI_MODEL=hy3-free

# Leave empty: the proxy talks to OpenCode Zen keyless, exactly like `opencode`.
export OPENAI_API_KEY=
