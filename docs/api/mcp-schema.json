{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mcp-schema.json",
  "title": "Torvox MCP Server",
  "description": "JSON-RPC 2.0 API for Torvox terminal emulator MCP server over Unix domain socket. Exposes terminal session state to AI agents for inspection and structured interaction.",
  "type": "object",
  "properties": {
    "jsonrpc": {
      "const": "2.0",
      "description": "JSON-RPC protocol version"
    },
    "methods": {
      "type": "object",
      "description": "JSON-RPC methods supported by the server",
      "properties": {
        "initialize": {
          "description": "MCP initialization handshake. Returns protocol version, server info, and capabilities.",
          "params": {
            "type": "object",
            "properties": {
              "protocolVersion": {
                "type": "string",
                "description": "MCP protocol version requested by the client"
              },
              "clientInfo": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "version": { "type": "string" }
                },
                "description": "Client identification"
              },
              "capabilities": {
                "type": "object",
                "description": "Client capabilities"
              }
            }
          },
          "result": {
            "type": "object",
            "properties": {
              "protocolVersion": { "const": "2024-11-05" },
              "serverInfo": {
                "type": "object",
                "properties": {
                  "name": { "const": "torvox-mcp" },
                  "version": { "type": "string", "description": "Server version from Cargo.toml" }
                }
              },
              "capabilities": {
                "type": "object",
                "properties": {
                  "tools": { "type": "object" }
                }
              }
            }
          }
        },
        "tools/list": {
          "description": "List all available MCP tools",
          "params": {},
          "result": {
            "type": "object",
            "properties": {
              "tools": {
                "type": "array",
                "items": { "$ref": "#/$defs/ToolDefinition" }
              }
            }
          }
        },
        "tools/call": {
          "description": "Invoke a tool by name with arguments",
          "params": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "Tool name to invoke" },
              "arguments": {
                "type": "object",
                "description": "Tool-specific arguments"
              }
            },
            "required": ["name"]
          },
          "result": {
            "type": "object",
            "properties": {
              "content": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string", "enum": ["text", "json"] },
                    "text": { "type": "string" },
                    "data": {}
                  }
                }
              }
            }
          }
        },
        "ping": {
          "description": "Health check — returns empty object",
          "params": {},
          "result": { "type": "object" }
        },
        "notifications/initialized": {
          "description": "Client notification that initialization is complete (no response expected)",
          "params": {}
        }
      }
    }
  },
  "tools": [
    {
      "name": "list_sessions",
      "description": "List all active terminal sessions",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "json" },
                "data": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/SessionInfo" }
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "read_grid",
      "description": "Read current grid state of a session (rows × cols cells)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "integer", "minimum": 0 }
        },
        "required": ["session_id"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "json" },
                "data": { "$ref": "#/$defs/GridSnapshotData" }
              }
            }
          }
        }
      }
    },
    {
      "name": "read_scrollback",
      "description": "Read last N lines of scrollback",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "integer", "minimum": 0 },
          "max_lines": { "type": "integer", "minimum": 1, "maximum": 100000 }
        },
        "required": ["session_id", "max_lines"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "json" },
                "data": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Array of scrollback lines"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "read_cursor",
      "description": "Read cursor position (row, col) and visibility",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "integer", "minimum": 0 }
        },
        "required": ["session_id"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "json" },
                "data": { "$ref": "#/$defs/CursorInfo" }
              }
            }
          }
        }
      }
    },
    {
      "name": "read_selection",
      "description": "Read currently selected text (if any)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "integer", "minimum": 0 }
        },
        "required": ["session_id"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "json" },
                "data": {
                  "oneOf": [
                    { "type": "string" },
                    { "type": "null" }
                  ],
                  "description": "Selected text or null if no selection"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "read_title",
      "description": "Read the session title (from OSC 0/2)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "integer", "minimum": 0 }
        },
        "required": ["session_id"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "json" },
                "data": { "type": "string", "description": "Session title string" }
              }
            }
          }
        }
      }
    },
    {
      "name": "send_input",
      "description": "Write text to PTY (requires --mcp-allow-write consent)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "integer", "minimum": 0 },
          "data": { "type": "string", "description": "Text to write to the PTY" }
        },
        "required": ["session_id", "data"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "text" },
                "text": { "const": "wrote to PTY" }
              }
            }
          }
        }
      }
    },
    {
      "name": "send_signal",
      "description": "Send signal to child process (SIGINT/SIGTERM/SIGHUP/SIGQUIT). Requires --mcp-allow-write consent.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "integer", "minimum": 0 },
          "signal": {
            "type": "string",
            "enum": ["SIGINT", "SIGTERM", "SIGHUP", "SIGQUIT", "INT", "TERM", "HUP", "QUIT", "interrupt", "terminate", "hangup", "quit"],
            "description": "Signal to send. Accepts full names (SIGINT, SIGTERM, SIGHUP, SIGQUIT), short aliases (INT, TERM, HUP, QUIT), or long aliases (interrupt, terminate, hangup, quit)"
          }
        },
        "required": ["session_id", "signal"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "text" },
                "text": { "const": "sent signal" }
              }
            }
          }
        }
      }
    },
    {
      "name": "get_app_info",
      "description": "Get app version and capabilities",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "json" },
                "data": { "$ref": "#/$defs/AppInfo" }
              }
            }
          }
        }
      }
    },
    {
      "name": "scrollback_search",
      "description": "Search scrollback buffer for a text pattern (regex)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "integer", "minimum": 0 },
          "pattern": { "type": "string", "description": "Text or regex pattern to search for" },
          "max_matches": { "type": "integer", "minimum": 1, "maximum": 1000, "default": 50 }
        },
        "required": ["session_id", "pattern"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "json" },
                "data": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/SearchMatch" }
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "set_terminal_size",
      "description": "Resize terminal to specified rows and cols (requires write consent)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "integer", "minimum": 0 },
          "rows": { "type": "integer", "minimum": 1, "maximum": 1000 },
          "cols": { "type": "integer", "minimum": 1, "maximum": 1000 }
        },
        "required": ["session_id", "rows", "cols"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "text" },
                "text": { "type": "string", "description": "Confirmation message with new dimensions" }
              }
            }
          }
        }
      }
    },
    {
      "name": "list_directory",
      "description": "List files in a local directory",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "File or directory path" }
        },
        "required": ["path"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "json" },
                "data": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/DirEntry" }
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "read_file",
      "description": "Read contents of a local file (text, limited lines)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "path": { "type": "string", "description": "File or directory path" },
          "max_lines": { "type": "integer", "minimum": 1, "maximum": 100000, "default": 1000 }
        },
        "required": ["path"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "json" },
                "data": { "$ref": "#/$defs/FileContent" }
              }
            }
          }
        }
      }
    },
    {
      "name": "read_clipboard",
      "description": "Read current clipboard content",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "text" },
                "text": { "type": "string", "description": "Clipboard content" }
              }
            }
          }
        }
      }
    },
    {
      "name": "write_clipboard",
      "description": "Write text to clipboard (requires write consent)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "text": { "type": "string", "description": "Text to write to clipboard" }
        },
        "required": ["text"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "text" },
                "text": { "const": "clipboard updated" }
              }
            }
          }
        }
      }
    },
    {
      "name": "raise_notification",
      "description": "Show an Android notification (requires write consent)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "description": "Notification title" },
          "body": { "type": "string", "description": "Notification body text" }
        },
        "required": ["title", "body"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "text" },
                "text": { "const": "notification sent" }
              }
            }
          }
        }
      }
    },
    {
      "name": "scroll_terminal",
      "description": "Scroll terminal viewport by N lines (negative=up, positive=down). Returns new scroll offset",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "integer", "minimum": 0 },
          "lines": { "type": "integer", "description": "Number of lines to scroll (negative=up, positive=down)" }
        },
        "required": ["session_id", "lines"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "json" },
                "data": {
                  "type": "object",
                  "properties": {
                    "scroll_offset": { "type": "integer", "description": "New scroll offset after scrolling" }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "feed_terminal_output",
      "description": "Inject text into terminal as if the child process produced it (requires write consent)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "integer", "minimum": 0 },
          "text": { "type": "string", "description": "Text to inject as terminal output" }
        },
        "required": ["session_id", "text"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "text" },
                "text": { "const": "output fed to terminal" }
              }
            }
          }
        }
      }
    },
    {
      "name": "queue_terminal_input",
      "description": "Queue text to be typed when a prompt pattern appears in scrollback (AI agent automation)",
      "inputSchema": {
        "type": "object",
        "properties": {
          "session_id": { "type": "integer", "minimum": 0 },
          "text": { "type": "string", "description": "Text to type when prompt pattern appears" },
          "prompt_pattern": { "type": "string", "description": "Regex pattern to watch for in scrollback output" },
          "timeout_seconds": { "type": "integer", "minimum": 1, "description": "Timeout in seconds after which the queued input expires" },
          "submit_key": { "type": "string", "description": "Key sequence to send after the text (default: carriage return)", "default": "\r" }
        },
        "required": ["session_id", "text", "prompt_pattern"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "text" },
                "text": { "type": "string", "description": "Confirmation message with entry ID" }
              }
            }
          }
        }
      }
    },
    {
      "name": "list_queued_inputs",
      "description": "List all pending queued inputs",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "json" },
                "data": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/QueuedEntryInfo" }
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "cancel_queued_input",
      "description": "Cancel a pending queued input by its entry_id",
      "inputSchema": {
        "type": "object",
        "properties": {
          "entry_id": { "type": "string", "description": "Unique identifier of the queued input to cancel" }
        },
        "required": ["entry_id"],
        "additionalProperties": false
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "const": "text" },
                "text": { "type": "string", "description": "Confirmation or not-found message" }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "ToolDefinition": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Tool name" },
        "description": { "type": "string", "description": "Tool description" },
        "inputSchema": {
          "type": "object",
          "description": "JSON Schema for tool input parameters"
        }
      }
    },
    "SessionInfo": {
      "type": "object",
      "description": "Information about a terminal session",
      "properties": {
        "id": { "type": "integer", "description": "Session identifier" },
        "title": { "type": "string", "description": "Session title from OSC 0/2" },
        "rows": { "type": "integer", "description": "Number of rows in the terminal grid" },
        "cols": { "type": "integer", "description": "Number of columns in the terminal grid" },
        "shell": { "type": "string", "description": "Shell executable path" },
        "pid": { "type": "integer", "description": "Process ID of the child process, if available" },
        "is_exited": { "type": "boolean", "description": "Whether the child process has exited" }
      },
      "required": ["id", "title", "rows", "cols", "shell", "is_exited"]
    },
    "GridSnapshotData": {
      "type": "object",
      "description": "Snapshot of the terminal grid state",
      "properties": {
        "rows": { "type": "integer", "description": "Number of rows in the grid" },
        "cols": { "type": "integer", "description": "Number of columns in the grid" },
        "cells": {
          "type": "array",
          "items": { "$ref": "#/$defs/GridCellData" },
          "description": "Visible cells in the grid"
        },
        "cursor_row": { "type": "integer", "description": "Cursor row position" },
        "cursor_col": { "type": "integer", "description": "Cursor column position" },
        "cursor_visible": { "type": "boolean", "description": "Whether the cursor is visible" }
      },
      "required": ["rows", "cols", "cells", "cursor_row", "cursor_col", "cursor_visible"]
    },
    "GridCellData": {
      "type": "object",
      "description": "A single cell in the terminal grid with text and attributes",
      "properties": {
        "row": { "type": "integer", "description": "Row position (0-based)" },
        "col": { "type": "integer", "description": "Column position (0-based)" },
        "codepoint": { "type": "integer", "description": "Unicode codepoint value" },
        "fg_r": { "type": "integer", "minimum": 0, "maximum": 255, "description": "Foreground red channel" },
        "fg_g": { "type": "integer", "minimum": 0, "maximum": 255, "description": "Foreground green channel" },
        "fg_b": { "type": "integer", "minimum": 0, "maximum": 255, "description": "Foreground blue channel" },
        "bg_r": { "type": "integer", "minimum": 0, "maximum": 255, "description": "Background red channel" },
        "bg_g": { "type": "integer", "minimum": 0, "maximum": 255, "description": "Background green channel" },
        "bg_b": { "type": "integer", "minimum": 0, "maximum": 255, "description": "Background blue channel" },
        "bold": { "type": "boolean" },
        "italic": { "type": "boolean" },
        "underline": { "type": "boolean" },
        "reverse": { "type": "boolean" },
        "dim": { "type": "boolean" },
        "strikethrough": { "type": "boolean" },
        "blink": { "type": "boolean" },
        "hidden": { "type": "boolean" }
      },
      "required": ["row", "col", "codepoint", "fg_r", "fg_g", "fg_b", "bg_r", "bg_g", "bg_b", "bold", "italic", "underline", "reverse", "dim", "strikethrough", "blink", "hidden"]
    },
    "CursorInfo": {
      "type": "object",
      "description": "Cursor position and visibility",
      "properties": {
        "row": { "type": "integer", "description": "Cursor row (0-based)" },
        "col": { "type": "integer", "description": "Cursor column (0-based)" },
        "visible": { "type": "boolean", "description": "Whether the cursor is visible" }
      },
      "required": ["row", "col", "visible"]
    },
    "SearchMatch": {
      "type": "object",
      "description": "A single match from a scrollback search",
      "properties": {
        "line_number": { "type": "integer", "description": "Line number of the match" },
        "text": { "type": "string", "description": "Matching line text" },
        "start_col": { "type": "integer", "description": "Start column of the match" },
        "end_col": { "type": "integer", "description": "End column of the match" }
      },
      "required": ["line_number", "text", "start_col", "end_col"]
    },
    "DirEntry": {
      "type": "object",
      "description": "A directory entry listing",
      "properties": {
        "name": { "type": "string", "description": "File or directory name" },
        "is_dir": { "type": "boolean", "description": "Whether this entry is a directory" },
        "size": { "type": "integer", "description": "File size in bytes, if available" },
        "modified": { "type": "string", "description": "Last modified timestamp, if available" }
      },
      "required": ["name", "is_dir"]
    },
    "FileContent": {
      "type": "object",
      "description": "Contents of a text file",
      "properties": {
        "lines": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lines of text from the file"
        },
        "total_lines": { "type": "integer", "description": "Total number of lines in the file" },
        "truncated": { "type": "boolean", "description": "Whether the output was truncated due to max_lines limit" }
      },
      "required": ["lines", "total_lines", "truncated"]
    },
    "AppInfo": {
      "type": "object",
      "description": "Application version and capabilities information",
      "properties": {
        "name": { "const": "torvox" },
        "version": { "type": "string", "description": "Server version" },
        "protocol": { "const": "2024-11-05" },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of supported tool names"
        },
        "rendering": { "const": "gpu-wgpu" },
        "font_system": { "const": "cosmic-text" },
        "platform": { "const": "android" }
      }
    },
    "QueuedEntryInfo": {
      "type": "object",
      "description": "Information about a queued terminal input entry",
      "properties": {
        "entry_id": { "type": "string", "description": "Unique identifier for this queued entry" },
        "session_id": { "type": "integer", "description": "Session ID being monitored" },
        "text_preview": { "type": "string", "description": "Preview of the queued text (truncated to 40 chars)" },
        "prompt_pattern": { "type": "string", "description": "Regex pattern being watched for" },
        "seconds_remaining": { "type": "integer", "description": "Seconds until this entry expires" }
      },
      "required": ["entry_id", "session_id", "text_preview", "prompt_pattern", "seconds_remaining"]
    }
  }
}
